{
  "name": "purple-signals",
  "version": "0.1.0",
  "private": true,
  "description": "Recurring leadership pulse platform with anonymised, aggregated insights",
  "license": "MIT",
  "author": "Morgan Swan <morganswan@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/superlativeman/purple-signals.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "PGPASSWORD=postgres psql -h 127.0.0.1 -p 54322 -U postgres -d postgres -v ON_ERROR_STOP=1 -f supabase/tests/isolation_test.sql",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "dependencies": {
